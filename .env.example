# Copy this file to `.env` and fill in your key. `.env` is gitignored — never commit it.
#   cp .env.example .env        # macOS/Linux
#   Copy-Item .env.example .env # PowerShell
#
# Get a key at https://console.anthropic.com -> Settings -> API Keys.
# Load it for a run with: uv run --env-file .env python src/eval.py
ANTHROPIC_API_KEY=

# DVIDS API key for the v2 corpus fetch (public-domain DoD news).
# Read-only search needs only the PUBLIC key; the secret key is not used here.
# Get one at https://api.dvidshub.net (Create an Account).
DVIDS_API_KEY=

# --- Event loop (Kafka consumer -> tags writeback), src/consumer.py ---
# NOTE: INACTIVE / reference implementation. notes-api dropped Kafka in its Python
# port; the live enrichment path is the /classify HTTP endpoint, called from a
# notes-api BackgroundTask. consumer.py and the vars below are kept as a worked
# example of the event-driven alternative, not a running integration.
# The reference consumer reads NoteCreated events from notes-api and writes predicted
# tags back. Defaults match notes-api's old local setup (broker on 9092; API on 8081).
# Run it with:
#   uv run --env-file .env python src/consumer.py
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NOTE_EVENTS_TOPIC=note-events
KAFKA_GROUP_ID=defense-news-classifier
NOTES_API_BASE_URL=http://localhost:8081
