# Copy this file to `.env` and fill in your key. `.env` is gitignored — never commit it.
#   cp .env.example .env        # macOS/Linux
#   Copy-Item .env.example .env # PowerShell
#
# Get a key at https://console.anthropic.com -> Settings -> API Keys.
# Load it for a run with: uv run --env-file .env python src/eval.py
ANTHROPIC_API_KEY=
